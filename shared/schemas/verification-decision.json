{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verification Decision Record",
  "description": "Audit trail schema for adversarial verification decisions. Workflows return decision records in their output; the main loop appends to ledger/ledger.json. Agents never write to the ledger.",
  "type": "object",
  "properties": {
    "decision_id": {
      "type": "string",
      "description": "Unique identifier for this verification decision"
    },
    "workflow": {
      "type": "string",
      "description": "Name of the workflow that produced this decision"
    },
    "agent_role": {
      "type": "string",
      "description": "Role of the primary agent whose output was verified"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the verification"
    },
    "primary_verdict": {
      "type": "object",
      "properties": {
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "sources_count": {
          "type": "integer"
        },
        "claims_count": {
          "type": "integer"
        }
      },
      "required": ["confidence", "sources_count", "claims_count"]
    },
    "verification_verdict": {
      "type": "object",
      "properties": {
        "overall": {
          "type": "string",
          "enum": ["pass", "pass_with_flags", "fail"]
        },
        "verified_claims": {
          "type": "integer"
        },
        "flagged_claims_count": {
          "type": "integer"
        },
        "flagged_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": { "type": "string" },
              "issue": { "type": "string" },
              "severity": { "type": "string", "enum": ["high", "medium", "low"] }
            },
            "required": ["claim", "issue"]
          }
        }
      },
      "required": ["overall", "verified_claims", "flagged_claims_count"]
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dimension": { "type": "string" },
          "reviewer_1_score": { "type": "number" },
          "reviewer_2_score": { "type": "number" },
          "delta": { "type": "number" }
        },
        "required": ["dimension", "reviewer_1_score", "reviewer_2_score", "delta"]
      },
      "description": "Score divergences between independent reviewers (content-pipeline only)"
    },
    "human_review_required": {
      "type": "boolean"
    }
  },
  "required": ["decision_id", "workflow", "agent_role", "primary_verdict", "verification_verdict", "human_review_required"]
}
