{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deal Review Agent Output",
  "description": "Structured output from the deal-reviewer agent. Used by deal-review workflow.",
  "type": "object",
  "required": ["deal_id", "stage_ready", "human_review_required", "retrieval_gaps"],
  "properties": {
    "deal_id": { "type": "string" },
    "stage_ready": { "type": "boolean", "description": "True only if all evidence is present for the current stage" },
    "evidence_gaps": {
      "type": "array",
      "description": "Missing evidence field names per pipeline-engine.md stage requirements",
      "items": { "type": "string" }
    },
    "usage_rights": {
      "type": "object",
      "properties": {
        "ownership": { "type": "string", "description": "Who owns the final deliverable" },
        "duration": { "type": "string", "description": "Licensing duration (e.g. 90 days, perpetual)" },
        "platform_restrictions": { "type": "array", "items": { "type": "string" } },
        "ambiguous_clauses": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exclusivity_conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conflicting_deal_id", "category"],
        "properties": {
          "conflicting_deal_id": { "type": "string" },
          "category": { "type": "string" },
          "date_range": { "type": "string" }
        }
      }
    },
    "quality_score": { "type": "number", "description": "Composite quality gate score, null if not scored" },
    "quality_pass": { "type": "boolean", "description": "Null if not scored" },
    "open_flags": { "type": "array", "items": { "type": "string" } },
    "human_review_required": {
      "type": "boolean",
      "description": "Always true when exclusivity conflicts or ambiguous clauses exist"
    },
    "sources_consulted": { "type": "array", "items": { "type": "string" } },
    "retrieval_gaps": { "type": "array", "items": { "type": "string" } }
  }
}
