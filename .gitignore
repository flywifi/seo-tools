# Real CRM data and user snapshots: never committed. Only schemas and blank structures live in git.
pipeline/**/*.local.json
pipeline/**/*.local.*
# Real channel stats, credentials config, or dated voice snapshots go in *.local.json
pipeline/user-context/*.local.json

# Regenerable local caches (scoop L1/L2) and any *.local.* working file
*.local
*.local.db
*.local.json
shared/cache/*.db
shared/cache/*.local.db
bucket.manifest.json

# Build artifacts
dist/

# Secrets and credentials
.env
secrets.json
*.secret

# Traversal engine working files (operator reviews before any entry touches the registry)
traversal-candidates.json
traversal-visited.json

# Competitor intelligence snapshots (raw HTML, screenshots, SQLite index)
pipeline/competitor-snapshots/
.harvest-cache/
snapshots-log.json

# Contract-artifact store (P23): raw contract text and per-contract records
# (committed: only pipeline/contracts/contract.template.json and the deal-playbook template).
# Covered by pipeline/**/*.local.* above; listed here so the intent is explicit: contract TEXT is never committed.
pipeline/contracts/*.local.json
pipeline/user-context/deal-playbook.local.json
# Obligation register (P23 Phase 3): real dated obligations stay local; only the template is committed.
pipeline/user-context/obligation-register.local.json
obligations-bucket.manifest.json

# Video editing bridge (P22): generated interchange files + local edit packages
# (committed: only the *.template.json schema files under pipeline/editing/)
pipeline/editing/*.local.*
pipeline/editing/*.fcpxml
pipeline/editing/*.fcpxmld/
pipeline/editing/*.drt
pipeline/editing/*.otio
pipeline/editing/*.compressorsetting
editing-bucket.manifest.json

# Python
__pycache__/
*.pyc
.pytest_cache/
